//@version=6
indicator(title="EMA 20/60 + 天门地门复合指标 V2.2 + PA精简版", shorttitle="EMA_TM_DM_PA_V2.2", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ==========================================
// SECTION 1: EMA 20/60 趋势系统
// ==========================================
src = input(close, title="数据源", group="EMA 设置")
len20 = input.int(20, minval=1, title="短期 EMA 长度", group="EMA 设置")
len60 = input.int(60, minval=1, title="长期 EMA 长度", group="EMA 设置")

ema20 = ta.ema(src, len20)
ema60 = ta.ema(src, len60)

p20 = plot(ema20, title="EMA 20", color=color.blue, linewidth=2)
p60 = plot(ema60, title="EMA 60", color=color.orange, linewidth=2)

// 趋势色带
ribbonColor = ema20 > ema60 ? color.new(color.green, 85) : color.new(color.red, 85)
fill(p20, p60, color=ribbonColor, title="EMA 趋势色带")

// 交叉信号
plotshape(ta.crossover(ema20, ema60),  title="EMA 金叉", style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small, text="金叉")
plotshape(ta.crossunder(ema20, ema60), title="EMA 死叉", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small, text="死叉")

// ==========================================
// SECTION 2: 天门/地门逻辑 (含位置记录)
// ==========================================
show_lines = input.bool(true, title="显示 天门/地门画线", group="天门地门设置")
show_color = input.bool(true, title="开启 K线组合染色", group="天门地门设置")

rsi_length    = 3
tianmen_level = 80.0
dimen_level   = 20.0
rsi_val       = ta.rsi(close, rsi_length)

// 记录最新的门线价格供染色逻辑调用
var float last_tianmen_price = na
var float last_dimen_price   = na

// 基础判断
is_yang_1 = close[1] > open[1]
is_yin_1  = close[1] < open[1]
is_yang   = close > open
is_yin    = close < open

// --- 天门生成逻辑 ---
is_rsi_peak_1 = rsi_val[1] > rsi_val and rsi_val[1] > rsi_val[2]
if is_rsi_peak_1 and is_yang_1 and rsi_val[1] > tianmen_level
    int peak_A_index = -1
    for n = 2 to 5 by 1
        if rsi_val[n + 1] > rsi_val[n] and rsi_val[n + 1] > rsi_val[n + 2]
            if rsi_val[n + 1] > tianmen_level
                peak_A_index := n + 1
                break
    if peak_A_index != -1 and close[peak_A_index] > open[peak_A_index]
        if high[1] > high[peak_A_index] and rsi_val[1] < rsi_val[peak_A_index]
            min_rsi_gap = 100.0
            for j = 2 to peak_A_index - 1 by 1
                min_rsi_gap := math.min(min_rsi_gap, rsi_val[j])
            if min_rsi_gap < math.min(rsi_val[1], rsi_val[peak_A_index])
                last_tianmen_price := close[peak_A_index]
                if show_lines
                    line.new(x1 = bar_index[peak_A_index], y1 = last_tianmen_price, x2 = bar_index + 60, y2 = last_tianmen_price, color = color.new(color.red, 20), width = 2)
                    label.new(x = bar_index[1], y = last_tianmen_price, text = '天门', color = color.new(color.red, 100), textcolor = color.red, style = label.style_none, size = size.small)

// --- 地门生成逻辑 ---
is_rsi_valley_1 = rsi_val[1] < rsi_val and rsi_val[1] < rsi_val[2]
if is_rsi_valley_1 and is_yin_1 and rsi_val[1] < dimen_level
    int valley_A_index = -1
    for n = 2 to 5 by 1
        if rsi_val[n + 1] < rsi_val[n] and rsi_val[n + 1] < rsi_val[n + 2]
            if rsi_val[n + 1] < dimen_level
                valley_A_index := n + 1
                break
    if valley_A_index != -1 and close[valley_A_index] < open[valley_A_index]
        if low[1] < low[valley_A_index] and rsi_val[1] > rsi_val[valley_A_index]
            max_rsi_gap = 0.0
            for j = 2 to valley_A_index - 1 by 1
                max_rsi_gap := math.max(max_rsi_gap, rsi_val[j])
            if max_rsi_gap > math.max(rsi_val[1], rsi_val[valley_A_index])
                last_dimen_price := close[valley_A_index]
                if show_lines
                    line.new(x1 = bar_index[valley_A_index], y1 = last_dimen_price, x2 = bar_index + 60, y2 = last_dimen_price, color = color.new(color.green, 20), width = 2)
                    label.new(x = bar_index[1], y = last_dimen_price, text = '地门', color = color.new(color.green, 100), textcolor = color.green, style = label.style_none, size = size.small)

// ==========================================
// SECTION 3: 优化后的 N 字形突破染色逻辑
// ==========================================

// 1. 阳阴阳 (N字多头突破): 第一根阳线[2]，第二根回调不破其低点[1]，第三根突破其高点[0]
bool n_up = is_yang[2] and is_yin[1] and is_yang and close > high[2] and low[1] >= low[2]

// 2. 阴阳阴 (N字空头突破): 第一根阴线[2]，第二根反弹不破其高点[1]，第三根跌破其低点[0]
bool n_down = is_yin[2] and is_yang[1] and is_yin and close < low[2] and high[1] <= high[2]

// --- 门线过滤逻辑 ---
bool can_show_down = not na(last_dimen_price) and close < last_dimen_price
bool can_show_up   = not na(last_tianmen_price) ? close > last_tianmen_price : true

color base_color = na
if show_color
    if n_down and can_show_down
        base_color := color.green
    else if n_up and can_show_up
        base_color := color.red

barcolor(base_color, offset =  0, title = "K线染色(右)", editable = false)
barcolor(base_color, offset = -1, title = "K线染色(中)", editable = false)
barcolor(base_color, offset = -2, title = "K线染色(左)", editable = false)

// ==========================================
// SECTION 4: Smoothing MA 辅助线
// ==========================================
GRP_S = "Smoothing (基于 EMA 20)"
maTypeInput   = input.string("None", "平滑类型", options = ["None", "SMA", "SMA + Bollinger Bands", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group = GRP_S)
maLengthInput = input.int(14, "平滑长度", group = GRP_S)
bbMultInput   = input.float(2.0, "布林带标准差", minval = 0.001, maxval = 50, step = 0.5, group = GRP_S)

ma(source, length, MAtype) =>
    switch MAtype
        "SMA"                   => ta.sma(source, length)
        "SMA + Bollinger Bands" => ta.sma(source, length)
        "EMA"                   => ta.ema(source, length)
        "SMMA (RMA)"            => ta.rma(source, length)
        "WMA"                   => ta.wma(source, length)
        "VWMA"                  => ta.vwma(source, length)
        => na

enableMA = maTypeInput != "None"
isBB     = maTypeInput == "SMA + Bollinger Bands"
smoothingMA    = enableMA ? ma(ema20, maLengthInput, maTypeInput) : na
smoothingStDev = isBB ? ta.stdev(ema20, maLengthInput) * bbMultInput : na

plot(smoothingMA, "平滑均线", color=color.yellow, display = enableMA ? display.all : display.none)
bbUpperBand = plot(smoothingMA + smoothingStDev, title = "平滑上轨", color=color.gray, display = isBB ? display.all : display.none)
bbLowerBand = plot(smoothingMA - smoothingStDev, title = "平滑下轨", color=color.gray, display = isBB ? display.all : display.none)
fill(bbUpperBand, bbLowerBand, color= isBB ? color.new(color.gray, 90) : na, title="平滑填充")

// ==========================================
// SECTION 5: H & L Count (Price Action 计数) - 精简优化版
// ==========================================
useHLC = input.bool(defval = true, title = "使用 H & L 计数", group = "PA 计数设置")
HColor = input.color(defval = #089981, title = "H 颜色 (仅多头展示)", group = "PA 计数设置")
LColor = input.color(defval = #F23645, title = "L 颜色 (仅空头展示)", group = "PA 计数设置")
HLCInterval_Input = input.float(defval = 1.0, title = '间距系数', group = "PA 计数设置")

// 计算标签与K线的动态间距
pa_interval = ta.sma(high - low, 100) * HLCInterval_Input

// 判定当前趋势状态 (复用 Section 1 的 EMA20/60 逻辑)
bool is_uptrend   = ema20 > ema60
bool is_downtrend = ema20 < ema60

// --- High Count (多头计数) ---
var int HCount = 0
var float HLastL = na
var bool BullPB = false
var float BullPBL = na

if low < low[1]
    BullPB := true
    if BullPBL > low or na(BullPBL)
        BullPBL := low

if high > high[1] and BullPB and useHLC
    HCount := HCount + 1
    if BullPBL > HLastL or na(HLastL)
        HCount := 1
    HLastL := BullPBL
    BullPBL := na
    BullPB := false

    // 【优化核心】：仅在多头趋势下，且计数 <= 2 时打印标签
    if is_uptrend and HCount <= 2
        label.new(x = bar_index, y = high + pa_interval, text = 'H' + str.tostring(HCount), yloc = yloc.price, style = label.style_none, textcolor = HColor)

// --- Low Count (空头计数) ---
var int LCount = 0
var float LLastH = na
var bool BearPB = false
var float BearPBH = na

if high > high[1]
    BearPB := true
    if BearPBH < high or na(BearPBH)
        BearPBH := high

if low < low[1] and BearPB and useHLC
    LCount := LCount + 1
    if BearPBH < LLastH or na(LLastH)
        LCount := 1
    LLastH := BearPBH
    BearPBH := na
    BearPB := false

    // 【优化核心】：仅在空头趋势下，且计数 <= 2 时打印标签
    if is_downtrend and LCount <= 2
        label.new(x = bar_index, y = low - pa_interval, text = 'L' + str.tostring(LCount), yloc = yloc.price, style = label.style_none, textcolor = LColor)